FROM golang:1.25 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /conversion-webhook ./cmd/conversion-webhook

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /conversion-webhook /conversion-webhook
USER 65532:65532
ENTRYPOINT ["/conversion-webhook"]
